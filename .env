## ============================================
## Project
## ============================================
DEDUPLICATION_ROOT=.

## ============================================
## Logging
## ============================================
DEDUPLICATION_LOG_LEVEL=INFO
DEDUPLICATION_LOG_DIR=logs
DEDUPLICATION_LOG_FILE=app.log
DEDUPLICATION_LOG_MAX_BYTES=5242880
DEDUPLICATION_LOG_BACKUP_COUNT=5

## ============================================
## Runtime / Execution
## ============================================
DEDUPLICATION_ENV=dev
DEDUPLICATION_SEED=42
DEDUPLICATION_MAX_RECORDS=100000
DEDUPLICATION_NUM_PROCESSES=1

## ============================================
## API / Flask
## ============================================
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=0

## ============================================
## Input handling
## ============================================
DEDUPLICATION_ACCEPT_CSV=true
DEDUPLICATION_ACCEPT_JSON=true
DEDUPLICATION_DEFAULT_ENCODING=utf-8
DEDUPLICATION_DEFAULT_ID_COLUMN=id

## ============================================
## Preprocessing / Cleaning
## ============================================
DEDUPLICATION_ENABLE_TEXT_NORMALIZATION=true
DEDUPLICATION_ENABLE_EMAIL_ENRICHMENT=true
DEDUPLICATION_ENABLE_NAME_CANDIDATES=true
DEDUPLICATION_ENABLE_ADDRESS_CANDIDATES=true

## ============================================
## Fuzzy Matching / Deduplication
## ============================================
DEDUPLICATION_CLUSTER_THRESHOLD=0.5
DEDUPLICATION_LIST_SIMILARITY_THRESHOLD=85
DEDUPLICATION_ENABLE_ACTIVE_LEARNING=false

## ============================================
## Active Learning
## ============================================
DEDUPLICATION_ACTIVE_LEARNING_DIR=data/active_learning
DEDUPLICATION_USE_EXISTING_TRAINING=true

## ============================================
## Artifacts / Config
## ============================================
DEDUPLICATION_ARTIFACTS_DIR=artifacts
DEDUPLICATION_CONFIG_DIR=artifacts/config
DEDUPLICATION_DATA_CONTROL_FILE=data_control.json
DEDUPLICATION_SWAGGER_FILE=swagger.yaml
DEDUPLICATION_EXPORTS_DIR=artifacts/exports

## ============================================
## Data paths
## ============================================
DEDUPLICATION_DATA_DIR=data
DEDUPLICATION_RAW_DATA_DIR=data/raw

## ============================================
## Docker / Overrides (optional)
## ============================================
DEDUPLICATION_CONTAINER_USER=appuser
